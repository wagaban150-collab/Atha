# Atha - Environment Configuration Example
# Copy this file to .env in both backend and frontend directories
# and update with your actual values

# Backend Configuration
BACKEND_PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=atha_user
DB_PASSWORD=atha_password_secure_2026
DB_NAME=atha_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2026-atha
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# API Keys (External Services)
BINANCE_API_KEY=your-binance-api-key-here
BINANCE_API_SECRET=your-binance-api-secret-here

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# Logging
LOG_LEVEL=info

# CORS
CLIENT_URL=http://localhost:5173

# Frontend Configuration
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=Atha
VITE_APP_DESCRIPTION=Cryptocurrency Trading Platform
